{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config/openclaw/shared_memory_sources.schema.json",
  "type": "object",
  "required": ["roots"],
  "properties": {
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "include_globs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
