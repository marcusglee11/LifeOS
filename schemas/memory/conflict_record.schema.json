{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.local/schemas/memory/conflict_record.schema.json",
  "title": "LifeOS Phase 1 Conflict Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["conflict_id", "status", "records_in_conflict", "conflict_type", "materiality", "opened_utc", "escalation_date", "owner", "owner_action", "summary", "evidence"],
  "properties": {
    "conflict_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["open", "acknowledged", "blocked", "resolved", "archived"] },
    "records_in_conflict": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["path", "id"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "conflict_type": { "enum": ["contradiction", "duplicate", "scope_mismatch", "staleness", "authority_collision", "evidence_dispute"] },
    "materiality": { "enum": ["low", "medium", "high"] },
    "opened_utc": { "type": "string", "minLength": 1 },
    "escalation_date": { "type": "string", "minLength": 1 },
    "owner": { "const": "COO" },
    "owner_action": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "minItems": 1 },
    "resolution": { "type": ["string", "null"] },
    "resolved_utc": { "type": ["string", "null"] },
    "supersession_edges": { "type": "array" }
  }
}
