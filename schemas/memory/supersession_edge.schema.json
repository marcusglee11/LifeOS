{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.local/schemas/memory/supersession_edge.schema.json",
  "title": "LifeOS Phase 1 Supersession Edge",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "from_record",
    "to_record",
    "supersession_type",
    "reason",
    "decided_by",
    "decided_utc",
    "evidence"
  ],
  "properties": {
    "from_record": {
      "type": "string",
      "minLength": 1
    },
    "to_record": {
      "type": "string",
      "minLength": 1
    },
    "supersession_type": {
      "enum": [
        "replaces",
        "narrows",
        "broadens",
        "corrects",
        "archives"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "decided_by": {
      "const": "COO"
    },
    "decided_utc": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1
    }
  }
}
