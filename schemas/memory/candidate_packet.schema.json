{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifeos.local/schemas/memory/candidate_packet.schema.json",
  "title": "LifeOS Phase 1 Candidate Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "candidate_id",
    "source_agent",
    "source_packet_type",
    "source_packet_id",
    "generated_utc",
    "proposed_action",
    "proposed_record_kind",
    "proposed_authority_class",
    "scope",
    "requires_human_review",
    "authority_impact",
    "personal_inference",
    "sensitivity",
    "promotion_basis",
    "sources",
    "summary",
    "payload"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "source_agent": {
      "type": "string",
      "minLength": 1
    },
    "source_packet_type": {
      "type": "string",
      "minLength": 1
    },
    "source_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_utc": {
      "type": "string",
      "minLength": 1
    },
    "proposed_action": {
      "enum": ["create", "update", "supersede", "conflict_open", "archive"]
    },
    "proposed_record_kind": {
      "enum": [
        "fact",
        "preference",
        "rule",
        "decision",
        "state",
        "lesson",
        "pattern"
      ]
    },
    "proposed_authority_class": {
      "enum": [
        "observation",
        "agent_memory",
        "shared_knowledge",
        "canonical_doctrine"
      ]
    },
    "scope": {
      "enum": ["global", "project", "agent", "workflow", "infrastructure"]
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "authority_impact": {
      "enum": ["none", "low", "medium", "high"]
    },
    "personal_inference": {
      "type": "boolean"
    },
    "sensitivity": {
      "enum": ["public", "internal", "private", "sensitive", "secret"]
    },
    "retention_class": {
      "enum": ["session", "short", "medium", "long", "permanent"]
    },
    "classification": {
      "enum": [
        "discard",
        "session_only",
        "observation",
        "agent_memory_candidate",
        "shared_knowledge_candidate",
        "canonical_doctrine_candidate",
        "conflict_candidate",
        "archive_candidate"
      ]
    },
    "staging_status": {
      "enum": [
        "workorder_distillation",
        "candidate_packet",
        "memory_candidate",
        "promotion_candidate",
        "conflict_candidate",
        "prune_candidate",
        "review_digest"
      ]
    },
    "promotion_basis": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source_type", "locator", "captured_utc"],
      "properties": {
        "source_type": {
          "enum": [
            "conversation",
            "workorder",
            "repo_file",
            "commit",
            "issue",
            "pull_request",
            "receipt",
            "manual_note",
            "external_doc"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "quoted_evidence": {
          "type": "string"
        },
        "captured_utc": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string"
        },
        "commit_sha": {
          "type": "string"
        }
      }
    }
  }
}
